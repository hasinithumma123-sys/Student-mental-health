rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, id, phone, role (student/staff), name, email, isCounselor
    //
    // Collection: assessments
    // Fields: studentUid, score, riskLevel, stressLevel, moodPattern, sleepQuality, timestamp
    //
    // Collection: appointments
    // Fields: studentUid, counselorUid, dateTime, mode, status, details, createdAt
    //
    // Collection: sos
    // Fields: studentUid, timestamp, status
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isAuthenticated() && getUserData().role == 'staff';
    }

    function isCounselor() {
      return isStaff() && getUserData().isCounselor == true;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' || 
         (request.auth.token.email == "hasini.thumma123@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'id', 'role']) &&
             data.uid is string && data.id is string &&
             data.role in ['student', 'staff'] &&
             (!('phone' in data) || data.phone is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /assessments/{assessmentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentUid || isStaff());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.studentUid;
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentUid || request.auth.uid == resource.data.counselorUid || isStaff());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.studentUid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.studentUid || request.auth.uid == resource.data.counselorUid);
    }

    match /sos/{sosId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentUid || isCounselor());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.studentUid;
      allow update: if isCounselor();
    }
  }
}
